{"nodes": [{"id": "docs_control_data_plane_split", "label": "Control/Data Plane Split Proposal", "file_type": "document", "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The cloud backend cannot see a user's local filesystem, so any code that reads/writes local files or spawns rsync/ssh must run locally. This single rule determines the entire control/data plane split. Direct local-to-VM SSH is simpler and cheaper than routing bytes through a cloud relay. The MCP server must stay stdlib-only and stateless so it can be spawned/killed by the agent client \u2014 hosting a long-lived sync worker there would cause sync to die with the editor and risk two workers fighting over the same folder."}, {"id": "docs_cloud_control_plane", "label": "Cloud Control Plane", "file_type": "rationale", "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_local_data_plane_daemon", "label": "Local Data-Plane Daemon", "file_type": "rationale", "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_sync_session_contract", "label": "Sync Session Contract (cloud\u2192local)", "file_type": "concept", "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_lease_authority", "label": "Lease Authority (cloud-owned sync coordination)", "file_type": "concept", "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Do not attempt peer-to-peer lease coordination between local processes. The cloud is the only thing all local clients can see, so leases must live there to safely coordinate multiple local daemons."}, {"id": "docs_direction_policy", "label": "Direction Policy (per-subtree sync authority)", "file_type": "concept", "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "--delete + multi-client is a footgun; a stale client can wipe live work. Per-subtree direction policy in the sync session closes this gap."}, {"id": "docs_ssh_ca_model", "label": "SSH CA Credential Model", "file_type": "concept", "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prefer SSH CA: local daemon generates keypair (private key never leaves machine), cloud signs public key into short-TTL certificate scoped to one sandbox. Keeps private key local while validity/revocation/rotation belong to control plane."}], "edges": [{"source": "docs_control_data_plane_split", "target": "docs_cloud_control_plane", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_control_data_plane_split", "target": "docs_local_data_plane_daemon", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_control_data_plane_split", "target": "docs_sync_session_contract", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_control_data_plane_split", "target": "docs_lease_authority", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_control_data_plane_split", "target": "docs_direction_policy", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_control_data_plane_split", "target": "docs_ssh_ca_model", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_control_data_plane_split", "target": "docs_startup_cheatsheet", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_sync_session_contract", "target": "docs_direction_policy", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_sync_session_contract", "target": "docs_lease_authority", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_cloud_control_plane", "target": "docs_lease_authority", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}, {"source": "docs_cloud_control_plane", "target": "docs_ssh_ca_model", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md", "source_location": null, "weight": 1.0}], "hyperedges": [{"id": "control_data_plane_seam", "label": "Control/Data Plane Seam (sync session + lease + direction policy)", "nodes": ["docs_sync_session_contract", "docs_lease_authority", "docs_direction_policy", "docs_local_data_plane_daemon", "docs_cloud_control_plane"], "relation": "form", "confidence": "EXTRACTED", "confidence_score": 0.95, "source_file": "research_plugin/docs/CONTROL_DATA_PLANE_SPLIT.md"}]}