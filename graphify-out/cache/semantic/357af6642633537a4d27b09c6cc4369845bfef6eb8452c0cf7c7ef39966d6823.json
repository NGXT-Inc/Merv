{"nodes": [{"id": "docs_architecture", "label": "Research Plugin Architecture Document", "file_type": "document", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_design_thesis", "label": "Plugin Architecture Design Thesis", "file_type": "rationale", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "The old backend had too many first-class subsystems for MVP. The plug-in architecture shrinks the implementation: Codex does reasoning/editing/local scripting, MCP owns durable memory and mutation validation. This hard boundary keeps the implementation small while preserving correctness."}, {"id": "docs_architecture_experiment_state_machine", "label": "Experiment State Machine", "file_type": "concept", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_reviewer_identity", "label": "Server-Issued Reviewer Capability Token Model", "file_type": "rationale", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Local reviewer identity cannot rely on IP/machine boundaries. The MVP models identity as server-issued workflow capability: scoped one-time tokens tied to one target, one role, and immutable target snapshot. Not cryptographic proof of independent minds, but a practical local boundary with audit trail."}, {"id": "docs_architecture_mutation_model", "label": "MCP Mutation Model (all state changes via MCP tools)", "file_type": "rationale", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "All meaning-changing mutations go through MCP tools. Codex may edit files locally, but research state is not changed until MCP accepts a mutation. This ensures the MCP server is the single source of truth and prevents race conditions."}, {"id": "docs_architecture_sandbox_execution", "label": "Sandbox Execution: No Job Abstraction Pattern", "file_type": "rationale", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "There is no job abstraction. The agent requests a sandbox and runs shell commands directly over SSH. This keeps the interface simple: Codex owns the command execution, MCP owns policy/state/visibility. Avoids the complexity of a job queue abstraction."}, {"id": "docs_architecture_workflow_status_and_next", "label": "workflow.status_and_next Orientation Tool", "file_type": "concept", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "docs_architecture_data_model", "label": "Research Plugin Simplified Data Model (Project/Claim/Experiment/Resource/Review/Event)", "file_type": "concept", "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "docs_architecture", "target": "docs_architecture_design_thesis", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": "Design thesis", "weight": 1.0}, {"source": "docs_architecture", "target": "docs_architecture_experiment_state_machine", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "research_plugin/docs/ARCHITECTURE.md", "source_location": "Workflow model", "weight": 1.0}, {"source"