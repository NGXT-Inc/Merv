{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/merv/:path(.*\\.(?:js|mjs|css|png|jpe?g|svg|gif|ico|webp|webmanifest|json|xml|txt|woff2?|ttf|map|pdf|wasm))", "destination": "/:path" },
    { "source": "/merv/:path*", "destination": "/index.html" }
  ],
  "redirects": [
    { "source": "/", "destination": "/merv", "permanent": false },
    { "source": "/p/:path*", "destination": "/merv/p/:path*", "permanent": false }
  ]
}
